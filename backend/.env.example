# Firebase Configuration
# Option 1 (local): path to JSON key file
FIREBASE_SERVICE_ACCOUNT_KEY=service-account-key.json
# Option 2 (Render/CI): raw JSON content of service account key
FIREBASE_SERVICE_ACCOUNT_JSON=

# Backend Configuration
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Data Generation
DATA_GENERATION_INTERVAL=30  # seconds

# Optional self-ping for environments that idle-sleep services
SELF_PING_ENABLED=False
SELF_PING_URL=
SELF_PING_INTERVAL_MINUTES=10
