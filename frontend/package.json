{
  "name": "frontend",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "npx expo@54 start",
    "android": "npx expo@54 run:android",
    "ios": "npx expo@54 run:ios",
    "web": "npx expo@54 start --web",
    "eas:preflight": "node scripts/eas-preflight.js",
    "eas:build:preview": "npm run eas:preflight && npx --yes eas-cli@18.7.0 build --platform android --profile preview --clear-cache",
    "eas:build:production": "npm run eas:preflight && npx --yes eas-cli@18.7.0 build --platform android --profile production --clear-cache"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "6.5.20",
    "@react-navigation/native": "6.1.17",
    "@react-navigation/stack": "6.3.29",
    "expo": "~54.0.0",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.11.0",
    "getenv": "1.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "10.0.3",
    "zustand": "4.4.7"
  },
  "private": true,
  "devDependencies": {
    "babel-preset-expo": "~54.0.10"
  }
}
